{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@rstacruz/opencode-autoask",
    "version": "1.0.0",
    "type": "module",
    "description": "OpenCode plugin that automatically prompts the LLM to offer follow-up questions after every response",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "clean": "rm -rf dist",
        "build": "npm run clean && tsc",
        "prepublishOnly": "npm run build",
        "dev": "opencode plugin dev",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "keywords": ["opencode", "opencode-plugin", "plugin", "autoask"],
    "author": "rstacruz",
    "license": "MIT",
    "peerDependencies": {
        "@opencode-ai/plugin": ">=0.13.7"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.1.49",
        "@types/node": "^22.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.0.0"
    },
    "files": ["dist/", "README.md", "LICENSE"]
}
